{
  "DatabaseProvider": "SqlServer",
  "Ai": {
    "DefaultProvider": "Ollama",
    "DefaultModel": "qwen3.5:9b",
    "Providers": {
      "Ollama": {
        "BaseUrl": "http://localhost:11434",
        "DefaultModel": "qwen3.5:9b"
      },
      "OpenAI": {
        "Model": "gpt-4o",
        "ApiKey": "__AI_OPENAI_APIKEY__"
      },
      "Azure": {
        "Endpoint": "",
        "DeploymentName": "",
        "ApiKey": "__AI_AZURE_APIKEY__"
      },
      "Anthropic": {
        "Model": "claude-3-5-sonnet-20241022",
        "ApiKey": "__AI_ANTHROPIC_APIKEY__"
      }
    },
    "ProviderSettings": {
      "OpenAI": { "Temperature": 0.2, "MaxTokens": 2048 },
      "Azure": { "Temperature": 0.2, "MaxTokens": 2048 },
      "Anthropic": { "Temperature": 0.2, "MaxTokens": 2048 },
      "Ollama": { "Temperature": 0.2, "NumPredict": 2048 }
    },
    "FeatureModels": {
      "Proofread": { "Provider": "Ollama", "Model": "qwen3.5:9b" },
      "Proofread_en": { "Provider": "Ollama", "Model": "qwen2.5:14b" },
      "LinguisticAnalysis": { "Provider": "Ollama", "Model": "qwen3.5:9b" },
      "Summarization": { "Provider": "Ollama", "Model": "qwen3.5:9b" },
      "GenericChat": { "Provider": "Ollama", "Model": "qwen3.5:9b" }
    },
    "ProofreadChunkTargetWords": 500,
    "MaxParallelProofreadChunks": 2
  },
  "LanguageEngine": {
    "DefaultPipeline": {
      "Normalize": true,
      "Detect": true,
      "Rewrite": false,
      "Analyze": false
    },
    "LanguageTool": {
      "Enabled": true,
      "ServerUrl": "http://localhost:8081",
      "Language": "he"
    },
    "Models": {
      "DictaLM": "qwen3.5:9b",
      "HebrewNemo": "qwen3.5:9b",
      "TafBERTa": null
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
